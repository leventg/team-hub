# Application
PORT=3001
NODE_ENV=development

# Database (required by docker-compose and API)
DB_HOST=localhost
DB_PORT=5433
DB_USER=team_hub
DB_PASSWORD=          # REQUIRED — set a strong password
DB_NAME=team_hub
DB_SCHEMA=team_hub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Keycloak
KC_PORT=8081                  # Host port for Keycloak (container always uses 8080)
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=team-hub
KEYCLOAK_CLIENT_ID=team-hub-api
KEYCLOAK_CLIENT_SECRET=

# Keycloak Admin (docker-compose)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=    # REQUIRED — set a strong password

# JWT
JWKS_URI=http://localhost:8081/realms/team-hub/protocol/openid-connect/certs
JWT_ISSUER=http://localhost:8081/realms/team-hub
JWT_AUDIENCE=account

# CORS
CORS_ORIGIN=http://localhost:3000
